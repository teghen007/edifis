{
    "name": "pea/edifis-backend",
    "type": "project",
    "description": "EDIFIS — multi-tenant, offline-first school management platform (Cloud Brain + Lite Local Node).",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0",
        "laravel/octane": "^2.0",
        "laravel/sanctum": "^4.0",
        "laravel/horizon": "^5.0",
        "filament/filament": "^3.2",
        "spatie/laravel-permission": "^6.0",
        "stancl/tenancy": "^3.8",
        "maatwebsite/excel": "^3.1",
        "barryvdh/laravel-dompdf": "^3.0",
        "ramsey/uuid": "^4.7",
        "predis/predis": "^2.2"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.16",
        "phpstan/phpstan": "^1.11",
        "larastan/larastan": "^2.9",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": { "Tests\\": "tests/" }
    },
    "scripts": {
        "lint": "pint --test",
        "stan": "phpstan analyse",
        "test": "pest",
        "check": ["@lint", "@stan", "@test"]
    },
    "config": {
        "sort-packages": true,
        "platform": { "php": "8.3.13" },
        "allow-plugins": { "pestphp/pest-plugin": true },
        "audit": {
            "ignore": [
                "PKSA-q46n-4fdk-zjr4",
                "PKSA-8qx3-n5y5-vvnd",
                "PKSA-w7xr-vk7n-rstm",
                "PKSA-qzrn-rnz3-85w1",
                "PKSA-mdq4-51ck-6kdq"
            ],
            "abandoned": "report",
            "block-insecure": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

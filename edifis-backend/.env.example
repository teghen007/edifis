# ── EDIFIS backend environment ────────────────────────────────────────────────
# Copy to .env. The SAME codebase runs cloud or local node by EDIFIS_MODE (ADR-004).

APP_NAME=EDIFIS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# cloud | local  — the single switch that gates multi-tenancy, parent portal, payments
EDIFIS_MODE=local
EDIFIS_SCHOOL_CODE=pssnkwen          # used on a node; ignored on cloud
EDIFIS_NODE_ID=node-pssnkwen-01

# ── Database (PostgreSQL 16, ADR-012) ─────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=edifis
DB_USERNAME=edifis
DB_PASSWORD=secret

# ── Redis / queue / Horizon ───────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ── Octane ────────────────────────────────────────────────────────────────────
OCTANE_SERVER=swoole

# ── Auth (Sanctum, ADR-006) ───────────────────────────────────────────────────
# Short TTL: tokens cache for brief offline use and re-validate on reconnect.
SANCTUM_TOKEN_TTL_MINUTES=120
SANCTUM_OFFLINE_GRACE_MINUTES=720     # how long a cached token may be used fully offline
REVOCATION_LIST_PULL_ON_SYNC=true

# ── Sync (ADR-007) ────────────────────────────────────────────────────────────
SYNC_CLOUD_BASE_URL=https://pssnkwen.edifis.cm/api   # node -> cloud target
SYNC_DELTA_MAX_BATCH=500                              # records per envelope
SYNC_RATE_LIMIT_PER_MINUTE=120
SYNC_BACKOFF_BASE_SECONDS=2
SYNC_PRIORITY_LANE=accountability                     # flush these event types first

# ── Multi-tenancy (cloud only) ────────────────────────────────────────────────
TENANCY_CENTRAL_DOMAIN=edifis.cm

# ── Monitoring ────────────────────────────────────────────────────────────────
MONITORING_ENDPOINT=https://edifis.cm/api/monitoring/node-status
MONITORING_REPORT_INTERVAL_SECONDS=300

# ── Money ─────────────────────────────────────────────────────────────────────
CURRENCY=XAF                          # amounts stored as integer CFA minor units

# ── Parent notifications (cloud, ADR-018) ─────────────────────────────────────
# Web Push (VAPID). Generate with: php artisan webpush:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@edifis.cm
# SMS fallback gateway: 'log' now (writes to log); real aggregator deferred.
SMS_GATEWAY=log

# ── Mobile money (DEFERRED — ADR-011, do not enable) ──────────────────────────
MOMO_ENABLED=false

# ── FCM Push Notifications (ADR-018) ──────────────────────────────────────────
FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=
FCM_TEST_ACCESS_TOKEN=

# ── AI Brain (parent assistant + Principal VACUUM) ───────────────────────────
# provider: deepseek | glm | openai | anthropic
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_API_KEY=
AI_TIMEOUT=30

# EDIFIS production env — copy to .env.prod and fill in. NEVER commit the real file.
APP_NAME=EDIFIS
APP_ENV=production
APP_KEY=                         # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://myedifis.com

EDIFIS_MODE=cloud
TENANCY_CENTRAL_DOMAIN=myedifis.com

# Database (PostgreSQL 16)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=edifis
DB_USERNAME=edifis
DB_PASSWORD=CHANGE_ME_STRONG

# Redis / queue / cache
REDIS_HOST=redis
REDIS_CLIENT=predis
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# Auth
SANCTUM_TOKEN_TTL_MINUTES=120
SANCTUM_OFFLINE_GRACE_MINUTES=720

# Push — Web Push (portal)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@myedifis.com

# Push — FCM v1 (app); mount the service-account JSON into the container
FCM_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/var/www/storage/firebase-service-account.json

# Mail (for new-device OTP)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@myedifis.com

CURRENCY=XAF
MOMO_ENABLED=false
SMS_GATEWAY=log

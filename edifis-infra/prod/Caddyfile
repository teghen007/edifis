# EDIFIS production reverse proxy for myedifis.com
# - Apex serves the homepage (static landing).
# - Every *.myedifis.com school subdomain is proxied to the app and gets HTTPS
#   AUTOMATICALLY on first request (on-demand TLS), but ONLY if the app confirms
#   the subdomain is a registered tenant (the `ask` endpoint) — this prevents
#   cert-issuance abuse. Result: onboard a school => its subdomain just works.

{
	email admin@myedifis.com
	# On-demand TLS: issue a cert when a new (allowed) hostname is first hit.
	on_demand_tls {
		ask http://app:8000/api/tenancy/domain-allowed
		interval 2m
		burst 5
	}
}

# Homepage / central domain — served by the app (Laravel Blade marketing pages,
# the onboarding-request form, and the PEA super-admin Filament panel).
myedifis.com, www.myedifis.com {
	reverse_proxy app:8000
	encode gzip
}

# All school subdomains -> the EDIFIS app (tenant resolved by Host header).
# tls on_demand makes Caddy fetch a cert per subdomain on first visit.
*.myedifis.com {
	tls {
		on_demand
	}
	reverse_proxy app:8000
	encode gzip
}
